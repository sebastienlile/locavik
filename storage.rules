rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // SÉCURITÉ: Refus par défaut
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Photos états des lieux — images uniquement, max 5 Mo, propriétaire seulement
    match /etats_des_lieux/{locataireId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Quittances PDF
    match /receipts/{userId}/{fichier} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.contentType == 'application/pdf';
    }

    // Baux PDF
    match /baux/{userId}/{fichier} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.contentType == 'application/pdf';
    }

    // Signature bailleur (image)
    match /signatures/{userId}/{fichier} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 512 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
